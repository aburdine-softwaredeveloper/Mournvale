{
  "name": "mournvale",
  "version": "1.0.0",
  "description": "A multiplayer text-based MUD engine built in Node.js.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
"scripts": {
  "dev:server": "tsx watch src/server/index.ts",
  "dev:client": "vite",
  "dev": "concurrently -n SERVER,CLIENT -c green,blue \"npm run dev:server\" \"npm run dev:client\"",
  "build:client": "vite build",
  "build": "npm run build:client",
  "start": "tsx src/server/index.ts",
  "typecheck": "tsc --noEmit",
  "test": "node scripts/run-smoke.mjs"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aburdine-softwaredeveloper/Mournvale.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/aburdine-softwaredeveloper/Mournvale/issues"
  },
  "homepage": "https://github.com/aburdine-softwaredeveloper/Mournvale#readme",
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
